{
  "name": "monopoly",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:client": "pnpm --filter @monopoly/client dev",
    "dev:server": "pnpm --filter @monopoly/server dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "prettier --write \"apps/**/*.{ts,vue,css,json,md}\" \"packages/**/*.ts\"",
    "format:check": "prettier --check \"apps/**/*.{ts,vue,css,json,md}\" \"packages/**/*.ts\"",
    "infra:up": "docker compose up -d postgres redis",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "prettier": "^3.8.4",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.62.0",
    "vue-eslint-parser": "^10.4.1"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
